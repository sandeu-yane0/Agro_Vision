# ════════════════════════════════════════════════════════
# AgroVision Backend — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ════════════════════════════════════════════════════════

# ─── LLM Provider ────────────────────────────────────────
# Choisir : "groq" (gratuit) ou "claude" (payant mais meilleur)
LLM_PROVIDER=groq

# Groq (gratuit) → https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude Anthropic (optionnel) → https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Base de données ──────────────────────────────────────
# Supabase (gratuit) → https://supabase.com
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# Supabase clés pour stockage images (optionnel)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Serveur ──────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development

# ─── Météo ────────────────────────────────────────────────
# Open-Meteo est 100% gratuit — aucune clé requise

# ─── Notes ────────────────────────────────────────────────
# 1. Ne jamais committer le fichier .env sur GitHub
# 2. Le fichier .gitignore exclut déjà .env
# 3. Pour Railway/Render : configurer ces variables dans le dashboard
